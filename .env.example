# API
API_PORT=3000
NODE_ENV=development

# Azure SQL via Prisma (use sqlserver provider)
# Local dev via docker-compose: see docker-compose.yml
DATABASE_URL="sqlserver://localhost:1433;database=itsm;user=sa;password=YourStrong!Passw0rd;encrypt=true;trustServerCertificate=true"

# Entra ID (OIDC) - register an app in Entra and fill these
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUDIENCE=api://itsm

# JWT (dev fallback when ENTRA_TENANT_ID is empty)
JWT_DEV_SECRET=dev-only-change-me

# Azure Blob Storage (use azurite locally)
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;"
AZURE_STORAGE_CONTAINER=attachments

# Azure Service Bus (leave empty locally to use in-memory queue)
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_NOTIFICATIONS_QUEUE=notifications
SERVICE_BUS_SLA_QUEUE=sla
SERVICE_BUS_EVENTS_QUEUE=events

# App Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Web
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUDIENCE=api://itsm
