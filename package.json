{
  "name": "itsm-poc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:seed": "ts-node --compiler-options '{\"module\":\"commonjs\"}' prisma/seed.ts",
    "prisma:seed:demo": "ts-node --compiler-options '{\"module\":\"commonjs\"}' prisma/seed-demo.ts",
    "prisma:seed:bulk": "ts-node --compiler-options '{\"module\":\"commonjs\"}' prisma/seed-bulk.ts",
    "record:videos": "ts-node --compiler-options '{\"module\":\"commonjs\"}' e2e/record.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --compiler-options '{\"module\":\"commonjs\"}' prisma/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node": "^22.9.0",
    "playwright": "^1.59.1",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
